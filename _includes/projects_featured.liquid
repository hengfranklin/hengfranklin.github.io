{% assign featured_projects = site.projects | where: "featured", true | sort: "importance" %}
{% if featured_projects.size > 0 %}
  <section class="projects-featured">
    <div class="featured-eyebrow-label">Featured</div>
    <div class="featured-grid">
      {% for project in featured_projects %}
        <a class="featured-card" href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
          {% if project.img %}
            <div class="featured-image">
              {%
                include figure.liquid
                loading="eager"
                path=project.img
                sizes="(min-width: 768px) 600px, 100vw"
                alt=project.title
              %}
            </div>
          {% endif %}
          <div class="featured-body">
            {% if project.role %}<div class="featured-eyebrow">{{ project.role }}</div>{% endif %}
            <h3 class="featured-title">{{ project.title }}</h3>
            <p class="featured-text">{{ project.description }}</p>
            <div class="featured-cta">View project &rarr;</div>
          </div>
        </a>
      {% endfor %}
    </div>
  </section>
{% endif %}
